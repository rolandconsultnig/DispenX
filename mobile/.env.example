# Expo injects EXPO_PUBLIC_* at bundle time. Rebuild the app after any change here.
# Base URL must end with /api (no trailing slash). Requests use paths like /mobile/login.

# ─── Physical phone / production APK ─────────────────────────────────────
# Use your server's PUBLIC IP or DNS. Prefer nginx on staff (4603) or admin (4602)
# so /api is proxied to Node — do NOT use localhost on a real device.
#
#   EXPO_PUBLIC_API_BASE=http://13.53.33.63:4603/api
#
# AWS / firewall: allow inbound TCP on that port (4603 or 4602) on the instance
# security group. Port 4601 (direct API) must also be open if you use :4601/api.
#
# Test from your PC (should return JSON):
#   curl -s http://13.53.33.63:4603/api/mobile/organizations
#
# Then build a new APK / run release so the env is baked in:
#   cd mobile && npx expo export  # or your EAS / gradle release flow

# ─── Local dev (emulator/simulator on same machine as API) ───────────────
# EXPO_PUBLIC_API_BASE=http://localhost:4601/api

# ─── Android emulator → API on host ──────────────────────────────────────
# EXPO_PUBLIC_API_BASE=http://10.0.2.2:4601/api
