# Copied to .env for local overrides. Expo injects EXPO_PUBLIC_* at bundling time.
# Must end with /api — the app calls paths like /mobile/login (→ .../api/mobile/login).

# Local: API on port 4601 (matches server default).
EXPO_PUBLIC_API_BASE=http://localhost:4601/api

# Cloud: nginx on staff (4603) or admin (4602) proxies /api to the API — use the portal you expose:
# EXPO_PUBLIC_API_BASE=http://YOUR_PUBLIC_HOST:4603/api
# EXPO_PUBLIC_API_BASE=http://YOUR_PUBLIC_HOST:4602/api

# Android emulator → API on your dev machine:
# EXPO_PUBLIC_API_BASE=http://10.0.2.2:4601/api
