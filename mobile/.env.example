# Copied to .env for local overrides. Expo injects EXPO_PUBLIC_* at bundling time.
# Must end with /api — the app calls paths like /mobile/login (→ .../api/mobile/login).

EXPO_PUBLIC_API_BASE=http://13.53.33.63:4602/api

# If the API is exposed directly on port 4000 instead:
# EXPO_PUBLIC_API_BASE=http://13.53.33.63:4000/api

# Android emulator talking to API on your PC:
# EXPO_PUBLIC_API_BASE=http://10.0.2.2:4000/api
