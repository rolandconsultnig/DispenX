# Server
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cfms?schema=public"
JWT_SECRET="change-this-to-a-strong-random-secret-in-production"
JWT_EXPIRES_IN="8h"
PORT=4000
NODE_ENV=development

# HMAC key for offline POS transaction signing
POS_HMAC_SECRET="change-this-offline-pos-hmac-secret"

# Fuel price update (default pump price in Naira per liter)
DEFAULT_PUMP_PRICE=650
