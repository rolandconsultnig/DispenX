# Server
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cfms?schema=public"
JWT_SECRET="change-this-to-a-strong-random-secret-in-production"
JWT_EXPIRES_IN="8h"
# API listens on 4601 (local + production). Must match deploy/nginx.conf upstream dispenx_api.
PORT=4601
NODE_ENV=development

# When the API sits behind nginx/ALB, set to 1 so rate limits and logs use the real client IP (X-Forwarded-For).
# If unset, all users can share one IP and staff login rate limits will block everyone after a few attempts.
# Still set TRUST_PROXY=1 in production: code relaxes express-rate-limit proxy validation to avoid 500s.
TRUST_PROXY=1

# Optional: comma-separated allowed browser origins if staff/admin are on a different host than the API.
# Example: https://staff.example.com,https://admin.example.com
# CORS_ORIGIN=

# HMAC key for offline POS transaction signing
POS_HMAC_SECRET="change-this-offline-pos-hmac-secret"

# Station portal: dev Vite + production nginx listen on 4604.
# STATION_PORTAL_URL=http://localhost:4604

# Fuel price update (default pump price in Naira per liter)
DEFAULT_PUMP_PRICE=650
