generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  FLEET_MANAGER
  FINANCE
  STATION_ATTENDANT
}

enum QuotaType {
  NAIRA
  LITERS
}

enum CardStatus {
  ACTIVE
  BLOCKED
  LOST
  EXPIRED
}

enum TransactionSource {
  RFID
  QR_CODE
  NFC
}

enum RechargeType {
  TOP_UP
  RESET
  MONTHLY_ALLOCATION
}

enum TransactionSyncStatus {
  SYNCED
  PENDING
  FAILED
}

enum SettlementStatus {
  PENDING
  PARTIALLY_PAID
  SETTLED
  DISPUTED
}

enum FuelType {
  PMS  // Premium Motor Spirit (Petrol)
  AGO  // Automotive Gas Oil (Diesel)
  CNG  // Compressed Natural Gas
}

// ─── Organization ────────────────────────────────────────

model Organization {
  id                  String        @id @default(uuid())
  name                String
  address             String?
  phone               String?
  email               String?
  creditLimit         Float         @default(0) @map("credit_limit")
  settlementCycleDays Int           @default(30) @map("settlement_cycle_days")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  users       User[]
  employees   Employee[]
  settlements Settlement[]
  stations    StationWhitelist[]

  @@map("organizations")
}

// ─── User (Admin portal users) ───────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  role           UserRole @default(ADMIN)
  organizationId String   @map("organization_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("users")
}

// ─── Employee (card holders) ─────────────────────────────

model Employee {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  staffId        String     @map("staff_id")
  firstName      String     @map("first_name")
  lastName       String     @map("last_name")
  phone          String?
  email          String?
  rfidUid        String?    @unique @map("rfid_uid")
  pin            String?    // hashed PIN for second-factor auth
  passwordHash   String?    @map("password_hash") // for mobile app login
  quotaType      QuotaType  @default(NAIRA) @map("quota_type")
  quotaLiters    Float      @default(0) @map("quota_liters")
  quotaNaira     Float      @default(0) @map("quota_naira")
  balanceLiters  Float      @default(0) @map("balance_liters")
  balanceNaira   Float      @default(0) @map("balance_naira")
  fuelType       FuelType   @default(PMS) @map("fuel_type")
  cardStatus     CardStatus @default(ACTIVE) @map("card_status")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  transactions  Transaction[]
  qrTokens      QrToken[]
  recharges     RechargeLog[]
  disputes      Dispute[]
  quotaRequests QuotaRequest[]
  notifications Notification[]

  @@unique([organizationId, staffId])
  @@map("employees")
}

// ─── Petrol Station ──────────────────────────────────────

model Station {
  id                   String   @id @default(uuid())
  name                 String
  location             String?
  address              String?
  phone                String?
  pumpPriceNairaPerLiter Float  @default(650) @map("pump_price_naira_per_liter")  // legacy / PMS default
  pricePms              Float  @default(650) @map("price_pms")
  priceAgo              Float  @default(900) @map("price_ago")
  priceCng              Float  @default(300) @map("price_cng")
  apiKey               String?  @unique @map("api_key") // for POS terminal auth
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  transactions Transaction[]
  settlements  Settlement[]
  whitelist    StationWhitelist[]

  @@map("stations")
}

// ─── Station Whitelist (which orgs are allowed at which stations) ─

model StationWhitelist {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  stationId      String @map("station_id")

  organization Organization @relation(fields: [organizationId], references: [id])
  station      Station      @relation(fields: [stationId], references: [id])

  @@unique([organizationId, stationId])
  @@map("station_whitelist")
}

// ─── Transaction ─────────────────────────────────────────

model Transaction {
  id              String                @id @default(uuid())
  idempotencyKey  String                @unique @map("idempotency_key")
  employeeId      String                @map("employee_id")
  stationId       String                @map("station_id")
  amountLiters    Float                 @map("amount_liters")
  amountNaira     Float                 @map("amount_naira")
  pumpPriceAtTime Float                 @map("pump_price_at_time")
  quotaType       QuotaType             @map("quota_type")
  fuelType        FuelType              @default(PMS) @map("fuel_type")
  source          TransactionSource     @default(RFID) @map("source")
  posSerial       String?               @map("pos_serial")
  hmacSignature   String?               @map("hmac_signature")
  syncStatus      TransactionSyncStatus @default(SYNCED) @map("sync_status")
  transactedAt    DateTime              @default(now()) @map("transacted_at")
  syncedAt        DateTime?             @map("synced_at")
  createdAt       DateTime              @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  station  Station  @relation(fields: [stationId], references: [id])

  @@index([employeeId])
  @@index([stationId])
  @@index([transactedAt])
  @@map("transactions")
}

// ─── Settlement ──────────────────────────────────────────

model Settlement {
  id                 String           @id @default(uuid())
  stationId          String           @map("station_id")
  organizationId     String           @map("organization_id")
  periodStart        DateTime         @map("period_start")
  periodEnd          DateTime         @map("period_end")
  totalLiters        Float            @default(0) @map("total_liters")
  totalNairaDeducted Float            @default(0) @map("total_naira_deducted")
  transactionCount   Int              @default(0) @map("transaction_count")
  status             SettlementStatus @default(PENDING)
  invoicePdfUrl      String?          @map("invoice_pdf_url")
  paidAt             DateTime?        @map("paid_at")
  notes              String?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  station      Station      @relation(fields: [stationId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([stationId, organizationId, periodStart, periodEnd])
  @@index([organizationId])
  @@index([status])
  @@map("settlements")
}

// ─── QR Token (time-limited fuel authorization) ──────────

model QrToken {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  token       String   @unique
  pin         String   // hashed PIN used to generate this token
  expiresAt   DateTime @map("expires_at")
  used        Boolean  @default(false)
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([token])
  @@index([employeeId])
  @@index([expiresAt])
  @@map("qr_tokens")
}

// ─── Dispute ─────────────────────────────────────────────

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

model Dispute {
  id            String        @id @default(uuid())
  employeeId    String        @map("employee_id")
  transactionId String?       @map("transaction_id")
  issueType     String        @map("issue_type") // WRONG_AMOUNT, UNAUTHORIZED, STATION_ERROR, OTHER
  description   String
  status        DisputeStatus @default(OPEN)
  resolution    String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("disputes")
}

// ─── Quota Request ───────────────────────────────────────

enum QuotaRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model QuotaRequest {
  id             String             @id @default(uuid())
  employeeId     String             @map("employee_id")
  amountNaira    Float              @default(0) @map("amount_naira")
  amountLiters   Float              @default(0) @map("amount_liters")
  reason         String
  status         QuotaRequestStatus @default(PENDING)
  reviewedBy     String?            @map("reviewed_by")
  reviewNote     String?            @map("review_note")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("quota_requests")
}

// ─── Notification ────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  type       String   // RECHARGE, TRANSACTION, DISPUTE, QUOTA, SYSTEM
  title      String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Recharge Log (balance top-up history) ───────────────

model RechargeLog {
  id              String       @id @default(uuid())
  employeeId      String       @map("employee_id")
  rechargedBy     String       @map("recharged_by") // userId who performed recharge
  rechargeType    RechargeType @default(TOP_UP) @map("recharge_type")
  quotaType       QuotaType    @map("quota_type")
  amountNaira     Float        @default(0) @map("amount_naira")
  amountLiters    Float        @default(0) @map("amount_liters")
  balanceBefore   Float        @default(0) @map("balance_before")
  balanceAfter    Float        @default(0) @map("balance_after")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([createdAt])
  @@map("recharge_logs")
}
