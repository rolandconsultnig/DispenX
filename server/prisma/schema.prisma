generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  FLEET_MANAGER
  FINANCE
  STATION_ATTENDANT
}

enum QuotaType {
  NAIRA
  LITERS
}

enum CardStatus {
  ACTIVE
  BLOCKED
  LOST
  EXPIRED
}

enum TransactionSource {
  RFID
  QR_CODE
  NFC
}

enum RechargeType {
  TOP_UP
  RESET
  MONTHLY_ALLOCATION
}

enum TransactionSyncStatus {
  SYNCED
  PENDING
  FAILED
}

enum SettlementStatus {
  PENDING
  PARTIALLY_PAID
  SETTLED
  DISPUTED
}

enum FuelType {
  PMS  // Premium Motor Spirit (Petrol)
  AGO  // Automotive Gas Oil (Diesel)
  CNG  // Compressed Natural Gas
}

enum TelemetryDeviceKind {
  GPS_TRACKER
  OBD2_ADAPTER
  MOBILE_TABLET
}

// ─── Organization ────────────────────────────────────────

model Organization {
  id                  String        @id @default(uuid())
  name                String
  address             String?
  phone               String?
  email               String?
  creditLimit         Float         @default(0) @map("credit_limit")
  settlementCycleDays Int           @default(30) @map("settlement_cycle_days")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  users             User[]
  employees         Employee[]
  settlements       Settlement[]
  stations          StationWhitelist[]
  vehicles          Vehicle[]
  auditLogs         AuditLog[]
  savedReports      SavedReport[]
  storedDocuments   StoredDocument[]
  telemetryDevices  TelemetryDevice[]

  @@map("organizations")
}

// ─── User (Admin portal users) ───────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  role           UserRole @default(ADMIN)
  organizationId String   @map("organization_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization     Organization   @relation(fields: [organizationId], references: [id])
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  savedReports     SavedReport[]  @relation("SavedReportCreator")
  uploadedDocuments StoredDocument[] @relation("DocumentUploader")

  @@map("users")
}

// ─── Employee (card holders) ─────────────────────────────

model Employee {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  staffId        String     @map("staff_id")
  firstName      String     @map("first_name")
  lastName       String     @map("last_name")
  phone          String?
  email          String?
  rfidUid        String?    @unique @map("rfid_uid")
  pin            String?    // hashed PIN for second-factor auth
  passwordHash   String?    @map("password_hash") // for mobile app login
  quotaType      QuotaType  @default(NAIRA) @map("quota_type")
  quotaLiters    Float      @default(0) @map("quota_liters")
  quotaNaira     Float      @default(0) @map("quota_naira")
  balanceLiters  Float      @default(0) @map("balance_liters")
  balanceNaira   Float      @default(0) @map("balance_naira")
  fuelType       FuelType   @default(PMS) @map("fuel_type")
  cardStatus     CardStatus @default(ACTIVE) @map("card_status")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  transactions  Transaction[]
  qrTokens      QrToken[]
  recharges     RechargeLog[]
  disputes      Dispute[]
  quotaRequests QuotaRequest[]
  notifications Notification[]
  vehicles      Vehicle[]
  auditLogs     AuditLog[]

  @@unique([organizationId, staffId])
  @@map("employees")
}

// ─── Petrol Station ──────────────────────────────────────

// Station includes stationCode: public Station ID for attendant portal (3 letters + 4 digits, e.g. AAA0000).
model Station {
  id                   String   @id @default(uuid())
  name                 String
  stationCode          String   @unique @map("station_code")
  location             String?
  address              String?
  phone                String?
  pumpPriceNairaPerLiter Float  @default(650) @map("pump_price_naira_per_liter")  // legacy / PMS default
  pricePms              Float  @default(650) @map("price_pms")
  priceAgo              Float  @default(900) @map("price_ago")
  priceCng              Float  @default(300) @map("price_cng")
  apiKey               String?  @unique @map("api_key") // legacy POS / integrations
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  transactions Transaction[]
  settlements  Settlement[]
  whitelist    StationWhitelist[]
  attendants   StationAttendant[]

  @@map("stations")
}

// Station attendant: portal login uses station code + username + password.
model StationAttendant {
  id             String   @id @default(uuid())
  stationId      String   @map("station_id")
  username       String   @map("username")
  passwordHash   String   @map("password_hash")
  displayName    String?  @map("display_name")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, username])
  @@map("station_attendants")
}

// ─── Audit trail (compliance & security) ─────────────────

model AuditLog {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now()) @map("created_at")
  actorUserId     String?  @map("actor_user_id")
  actorEmployeeId String?  @map("actor_employee_id")
  organizationId  String?  @map("organization_id")
  action          String
  entityType      String   @map("entity_type")
  entityId        String?  @map("entity_id")
  metadata        Json?
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")

  actorUser     User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmployee Employee?     @relation(fields: [actorEmployeeId], references: [id], onDelete: SetNull)
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

// ─── Refresh tokens (optional rotation for admin/staff JWT) ─

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── Saved / scheduled report definitions ────────────────

model SavedReport {
  id                 String    @id @default(uuid())
  organizationId     String    @map("organization_id")
  createdByUserId    String    @map("created_by_user_id")
  name               String
  reportType         String    @map("report_type")
  filters            Json      @default("{}")
  scheduleEnabled    Boolean   @default(false) @map("schedule_enabled")
  cronExpression     String?   @map("cron_expression")
  lastScheduledRunAt DateTime? @map("last_scheduled_run_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("SavedReportCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdByUserId])
  @@map("saved_reports")
}

// ─── Document metadata (invoices, exports, attachments) ─

model StoredDocument {
  id               String   @id @default(uuid())
  organizationId   String   @map("organization_id")
  uploadedByUserId String?  @map("uploaded_by_user_id")
  settlementId     String?  @map("settlement_id")
  category         String
  fileName         String   @map("file_name")
  storageUrl       String   @map("storage_url")
  mimeType         String?  @map("mime_type")
  sizeBytes        Int?     @map("size_bytes")
  createdAt        DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation("DocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  settlement   Settlement?  @relation(fields: [settlementId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([settlementId])
  @@index([category])
  @@map("stored_documents")
}

// ─── Telemetry device registry (hardware inventory) ──────

model TelemetryDevice {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  vehicleId      String?             @map("vehicle_id")
  deviceKind     TelemetryDeviceKind @map("device_kind")
  externalId     String              @map("external_id")
  label          String?
  isActive       Boolean             @default(true) @map("is_active")
  lastSeenAt     DateTime?           @map("last_seen_at")
  metadata       Json?
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@unique([organizationId, deviceKind, externalId])
  @@index([vehicleId])
  @@index([organizationId])
  @@map("telemetry_devices")
}

// ─── Station Whitelist (which orgs are allowed at which stations) ─

model StationWhitelist {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  stationId      String @map("station_id")

  organization Organization @relation(fields: [organizationId], references: [id])
  station      Station      @relation(fields: [stationId], references: [id])

  @@unique([organizationId, stationId])
  @@map("station_whitelist")
}

// ─── Transaction ─────────────────────────────────────────

model Transaction {
  id              String                @id @default(uuid())
  idempotencyKey  String                @unique @map("idempotency_key")
  employeeId      String                @map("employee_id")
  stationId       String                @map("station_id")
  amountLiters    Float                 @map("amount_liters")
  amountNaira     Float                 @map("amount_naira")
  pumpPriceAtTime Float                 @map("pump_price_at_time")
  quotaType       QuotaType             @map("quota_type")
  fuelType        FuelType              @default(PMS) @map("fuel_type")
  source          TransactionSource     @default(RFID) @map("source")
  posSerial       String?               @map("pos_serial")
  hmacSignature   String?               @map("hmac_signature")
  syncStatus      TransactionSyncStatus @default(SYNCED) @map("sync_status")
  transactedAt    DateTime              @default(now()) @map("transacted_at")
  syncedAt        DateTime?             @map("synced_at")
  createdAt       DateTime              @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  station  Station  @relation(fields: [stationId], references: [id])

  @@index([employeeId])
  @@index([stationId])
  @@index([transactedAt])
  @@map("transactions")
}

// ─── Settlement ──────────────────────────────────────────

model Settlement {
  id                 String           @id @default(uuid())
  stationId          String           @map("station_id")
  organizationId     String           @map("organization_id")
  periodStart        DateTime         @map("period_start")
  periodEnd          DateTime         @map("period_end")
  totalLiters        Float            @default(0) @map("total_liters")
  totalNairaDeducted Float            @default(0) @map("total_naira_deducted")
  transactionCount   Int              @default(0) @map("transaction_count")
  status             SettlementStatus @default(PENDING)
  invoicePdfUrl      String?          @map("invoice_pdf_url")
  paidAt             DateTime?        @map("paid_at")
  notes              String?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  station          Station           @relation(fields: [stationId], references: [id])
  organization     Organization      @relation(fields: [organizationId], references: [id])
  storedDocuments  StoredDocument[]

  @@unique([stationId, organizationId, periodStart, periodEnd])
  @@index([organizationId])
  @@index([status])
  @@map("settlements")
}

// ─── QR Token (time-limited fuel authorization) ──────────

model QrToken {
  id           String    @id @default(uuid())
  employeeId   String    @map("employee_id")
  token        String    @unique
  pin          String    // hashed PIN used to generate this token
  expiresAt    DateTime  @map("expires_at")
  used         Boolean   @default(false)
  usedAt       DateTime? @map("used_at")
  amountNaira  Float?    @map("amount_naira")
  amountLiters Float?    @map("amount_liters")
  fuelType     FuelType? @map("fuel_type")
  createdAt    DateTime  @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([token])
  @@index([employeeId])
  @@index([expiresAt])
  @@map("qr_tokens")
}

// ─── Dispute ─────────────────────────────────────────────

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

model Dispute {
  id            String        @id @default(uuid())
  employeeId    String        @map("employee_id")
  transactionId String?       @map("transaction_id")
  issueType     String        @map("issue_type") // WRONG_AMOUNT, UNAUTHORIZED, STATION_ERROR, OTHER
  description   String
  status        DisputeStatus @default(OPEN)
  resolution    String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("disputes")
}

// ─── Quota Request ───────────────────────────────────────

enum QuotaRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model QuotaRequest {
  id             String             @id @default(uuid())
  employeeId     String             @map("employee_id")
  amountNaira    Float              @default(0) @map("amount_naira")
  amountLiters   Float              @default(0) @map("amount_liters")
  reason         String
  status         QuotaRequestStatus @default(PENDING)
  reviewedBy     String?            @map("reviewed_by")
  reviewNote     String?            @map("review_note")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("quota_requests")
}

// ─── Notification ────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  type       String   // RECHARGE, TRANSACTION, DISPUTE, QUOTA, SYSTEM
  title      String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Vehicle ─────────────────────────────────────────────

model Vehicle {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  employeeId      String?  @map("employee_id")
  plateNumber     String   @unique @map("plate_number")
  make            String?  // Toyota, Honda, etc.
  model           String?  // Corolla, Civic, etc.
  year            Int?
  vin             String?  @unique @map("vin") // Vehicle Identification Number
  fuelType        FuelType @default(PMS) @map("fuel_type")
  obd2DeviceId    String?  @map("obd2_device_id") // Bluetooth MAC or serial
  gpsTrackerId    String?  @map("gps_tracker_id")  // External GPS tracker ID
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee?    @relation(fields: [employeeId], references: [id])
  gpsPositions      GpsPosition[]
  obd2Readings      Obd2Reading[]
  telemetryDevices  TelemetryDevice[]

  @@index([organizationId])
  @@index([employeeId])
  @@map("vehicles")
}

// ─── GPS Position ────────────────────────────────────────

model GpsPosition {
  id         String   @id @default(uuid())
  vehicleId  String   @map("vehicle_id")
  latitude   Float
  longitude  Float
  altitude   Float?
  speed      Float?   // km/h
  heading    Float?   // degrees 0-360
  accuracy   Float?   // meters
  source     String   @default("DEVICE") // DEVICE (phone GPS), TRACKER (external), MANUAL
  recordedAt DateTime @map("recorded_at") // when the reading was taken
  createdAt  DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([recordedAt])
  @@index([vehicleId, recordedAt])
  @@map("gps_positions")
}

// ─── OBD2 Reading ────────────────────────────────────────

model Obd2Reading {
  id                 String   @id @default(uuid())
  vehicleId          String   @map("vehicle_id")
  // Engine / performance
  rpm                Float?   // Engine RPM
  speed              Float?   // Vehicle speed km/h (from OBD)
  throttlePosition   Float?   @map("throttle_position") // 0-100%
  engineLoad         Float?   @map("engine_load") // 0-100%
  engineCoolantTemp  Float?   @map("engine_coolant_temp") // °C
  intakeAirTemp      Float?   @map("intake_air_temp") // °C
  // Fuel
  fuelLevel          Float?   @map("fuel_level") // 0-100%
  fuelPressure       Float?   @map("fuel_pressure") // kPa
  fuelRate           Float?   @map("fuel_rate") // L/h
  maf                Float?   // Mass Air Flow g/s
  // Diagnostics
  dtcCodes           String[] @map("dtc_codes") // Diagnostic Trouble Codes e.g. ["P0301", "P0420"]
  milStatus          Boolean  @default(false) @map("mil_status") // Malfunction Indicator Lamp
  batteryVoltage     Float?   @map("battery_voltage") // Volts
  odometer           Float?   // km
  runTime            Int?     @map("run_time") // seconds since engine start
  // Meta
  recordedAt         DateTime @map("recorded_at")
  createdAt          DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([recordedAt])
  @@index([vehicleId, recordedAt])
  @@map("obd2_readings")
}

// ─── Recharge Log (balance top-up history) ───────────────

model RechargeLog {
  id              String       @id @default(uuid())
  employeeId      String       @map("employee_id")
  rechargedBy     String       @map("recharged_by") // userId who performed recharge
  rechargeType    RechargeType @default(TOP_UP) @map("recharge_type")
  quotaType       QuotaType    @map("quota_type")
  amountNaira     Float        @default(0) @map("amount_naira")
  amountLiters    Float        @default(0) @map("amount_liters")
  balanceBefore   Float        @default(0) @map("balance_before")
  balanceAfter    Float        @default(0) @map("balance_after")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([createdAt])
  @@map("recharge_logs")
}
